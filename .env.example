# FakeSpotter environment configuration
# Copy to .env and fill in your values

# Cryptographic signing key for Forensic Certificates
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FAKESPOTTER_SECRET=change-me-to-a-strong-random-secret

# Transport mode: stdio (Claude Desktop) or streamable_http (Docker/remote)
FAKESPOTTER_TRANSPORT=stdio

# HTTP server port (only used when TRANSPORT=streamable_http)
FAKESPOTTER_PORT=8000

# Temporary files directory (created automatically)
FAKESPOTTER_TMP=/tmp/fakespotter
